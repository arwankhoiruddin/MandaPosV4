APP_NAME="NexoPOS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app-name.up.railway.app

LOG_CHANNEL=stack

# Railway auto-injects DATABASE_URL for PostgreSQL
# No need to set DB_HOST/DB_PORT/DB_DATABASE/DB_USERNAME/DB_PASSWORD manually
DB_CONNECTION=pgsql

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_COOKIE=nexopos_session

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
SANCTUM_STATEFUL_DOMAINS=your-app-name.up.railway.app
NS_ENV=production

REVERB_SERVER_HOST="127.0.0.1"
REVERB_HOST="127.0.0.1"
REVERB_PORT=443
REVERB_SCHEME=http

TELESCOPE_ENABLED=false

# External translation service base URL (without trailing slash), e.g. http://host.docker.internal:3000
TRANSLATOR_ENDPOINT=
